---
interface Props {
	svgCode: string;
	/** Pixel dimension; the cell is square (width === height). */
	size: number;
	/**
	 * Optional initial background colour.
	 * Sets --preview-bg on this element directly, which overrides the value
	 * inherited from #preview-root. Useful for standalone use (e.g. index
	 * page thumbnails) where BgSelector is not present.
	 */
	bgColor?: string;
}

const { svgCode, size, bgColor } = Astro.props;

/**
 * Override width/height on the root <svg> element so it fills its container.
 * The container .icon-box div handles the actual pixel sizing via inline style.
 *
 * SECURITY NOTE: svgCode is injected as raw HTML without sanitisation.
 * This is intentional — this tool is for local development use only, where
 * the developer controls all SVG input. Do not expose to untrusted content.
 */
function normalizeSvg(code: string): string {
	return code.replace(
		/<svg\b([^>]*)>/,
		(_, attrs: string) => {
			const cleaned = attrs
				// Remove any existing width/height attributes (quoted with " or ')
				.replace(/\s+width\s*=\s*(?:"[^"]*"|'[^']*')/g, "")
				.replace(/\s+height\s*=\s*(?:"[^"]*"|'[^']*')/g, "");
			return `<svg${cleaned} width="100%" height="100%">`;
		},
	);
}

const normalizedSvg = normalizeSvg(svgCode);
---

<div class="icon-cell">
	<!--
		Background is driven by --preview-bg, which BgSelector updates on
		#preview-root; all descendant .icon-box elements inherit it via CSS.
		bgColor prop sets it locally for cases with no BgSelector in the tree.
	-->
	<div
		class="icon-box"
		style={`width: ${size}px; height: ${size}px;${bgColor != null ? ` --preview-bg: ${bgColor};` : ""}`}
		set:html={normalizedSvg}
	/>
	<span class="icon-cell__label">{size}px</span>
</div>

<style>
	.icon-cell {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-1);
		/* Prevent cells from shrinking inside the horizontally scrolling row. */
		flex-shrink: 0;
	}

	.icon-box {
		/* 1px border keeps white icons visible on a white background. */
		border: 1px solid var(--color-border);
		background-color: var(--preview-bg, #ffffff);
		overflow: hidden;
		transition: background-color 0.2s ease;
	}

	.icon-cell__label {
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		font-family: var(--font-mono);
		white-space: nowrap;
	}
</style>
