---
import type { Project } from "../data/projects.ts";
import IconPreview from "./IconPreview.astro";

interface Props {
	project: Project;
}

const { project } = Astro.props;
// A thumbnail only makes sense if there is at least one icon.
const firstIcon = project.icons[0];
---

<a href={`/projects/${project.slug}`} class="project-card">
	{
		firstIcon && (
			<div class="project-card__thumb">
				<IconPreview svgCode={firstIcon.svgCode} size={32} bgColor="#ffffff" />
			</div>
		)
	}
	<div class="project-card__body">
		<span class="project-card__name">{project.name}</span>
		{project.description && <span class="project-card__desc">{project.description}</span>}
	</div>
</a>

<style>
	.project-card {
		display: flex;
		align-items: flex-start;
		gap: var(--space-3);
		padding: var(--space-4);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		color: inherit;
		text-decoration: none;
		transition:
			border-color 0.15s,
			box-shadow 0.15s;
	}

	.project-card:hover {
		border-color: var(--color-border-strong);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
		text-decoration: none;
	}

	.project-card__thumb {
		flex-shrink: 0;
		/* Prevent the thumbnail's 1px cell border from adding unexpected padding. */
		line-height: 0;
	}

	.project-card__body {
		display: flex;
		flex-direction: column;
		gap: var(--space-1);
		min-width: 0;
	}

	.project-card__name {
		font-weight: 600;
		font-size: var(--text-base);
		color: var(--color-link);
	}

	.project-card__desc {
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		line-height: 1.4;
		/* Clamp to 2 lines to keep cards uniform in the grid. */
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
