---
// Hardcoded palette per spec; order is intentional.
const BACKGROUNDS = [
	{ label: "White", value: "#ffffff" },
	{ label: "Light Grey", value: "#f0f0f0" },
	{ label: "Mid Grey", value: "#808080" },
	{ label: "Dark Grey", value: "#333333" },
	{ label: "Black", value: "#000000" },
	{ label: "Brand Blue", value: "#1d4ed8" },
	{ label: "Brand Green", value: "#16a34a" },
	{ label: "Warm Tan", value: "#d4a574" },
	{ label: "Hot Pink", value: "#db2777" },
] as const;
---

<div class="bg-selector">
	<span class="bg-selector__label">Background:</span>
	<div class="bg-selector__swatches" role="group" aria-label="Background colour">
		{
			BACKGROUNDS.map((bg) => (
				<button
					class="swatch"
					data-color={bg.value}
					title={bg.label}
					aria-label={bg.label}
					style={`background-color: ${bg.value};`}
				/>
			))
		}
	</div>
</div>

<script>
	const root = document.getElementById("preview-root");
	const swatches = document.querySelectorAll<HTMLButtonElement>(".swatch");

	function applyColor(color: string): void {
		// Update the CSS custom property on #preview-root. All descendant
		// .icon-box elements inherit --preview-bg and repaint immediately.
		if (root) {
			root.style.setProperty("--preview-bg", color);
			// Mirror as a data attribute for external reference if needed.
			root.dataset.bg = color;
		}
		// Mark the active swatch visually.
		swatches.forEach((s) => {
			s.classList.toggle("active", s.dataset.color === color);
		});
	}

	// White is the default on load, matching the inline style on #preview-root.
	applyColor("#ffffff");

	swatches.forEach((swatch) => {
		swatch.addEventListener("click", () => {
			applyColor(swatch.dataset.color ?? "#ffffff");
		});
	});
</script>

<style>
	.bg-selector {
		display: flex;
		align-items: center;
		gap: var(--space-3);
		margin-bottom: var(--space-6);
		padding: var(--space-3) var(--space-4);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
	}

	.bg-selector__label {
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		white-space: nowrap;
		font-weight: 500;
	}

	.bg-selector__swatches {
		display: flex;
		gap: var(--space-2);
		flex-wrap: wrap;
	}

	.swatch {
		width: 28px;
		height: 28px;
		border-radius: var(--radius-full);
		border: 2px solid var(--color-border);
		cursor: pointer;
		padding: 0;
		transition:
			border-color 0.1s,
			transform 0.1s,
			box-shadow 0.1s;
	}

	.swatch:hover {
		border-color: var(--color-border-strong);
		transform: scale(1.1);
	}

	/* Active state: double-ring using box-shadow so border stays visible. */
	.swatch.active {
		border-color: var(--color-text);
		box-shadow:
			0 0 0 2px var(--color-surface),
			0 0 0 4px var(--color-text);
	}
</style>
